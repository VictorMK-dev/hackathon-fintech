  "glossario": [
    { "termo": "Dividend Yield (DY)",     "definicao": "Percentual dos dividendos pagos em relação ao preço da ação. Quanto maior, mais renda o ativo distribui." },
    { "termo": "P/L (Preço/Lucro)",       "definicao": "Quantos anos levaria para recuperar o investimento com o lucro atual. Menor pode indicar ativo mais barato." },
    { "termo": "P/VP (Preço/Valor Patrimonial)", "definicao": "Compara o preço de mercado com o valor contábil. P/VP < 1 pode indicar ativo subavaliado." },
    { "termo": "ROE",                     "definicao": "Retorno sobre o patrimônio líquido. Mede a eficiência da empresa em gerar lucro com seus recursos." },
    { "termo": "Vacância (FIIs)",         "definicao": "Percentual de área vaga nos imóveis do fundo. Vacância baixa é positiva para o rendimento." },
    { "termo": "Tesouro Selic",           "definicao": "Título público indexado à taxa Selic. Indicado para reserva de emergência por ter liquidez diária." },
    { "termo": "IPCA+",                   "definicao": "Título público que paga a inflação (IPCA) mais uma taxa prefixada. Protege o poder de compra." },
    { "termo": "Selic",                   "definicao": "Taxa básica de juros da economia brasileira, definida pelo Banco Central (COPOM)." },
    { "termo": "Marcação a mercado",      "definicao": "Atualização diária do preço de um ativo com base no valor de mercado. Pode causar oscilações no curto prazo." },
    { "termo": "FOF (Fundo de Fundos)",   "definicao": "FII que investe em cotas de outros fundos imobiliários. Oferece diversificação automática." },
    { "termo": "CRI (Certificado de Recebíveis Imobiliários)", "definicao": "Título de renda fixa lastreado em créditos imobiliários. Comum em FIIs de papel." },
    { "termo": "B3",                      "definicao": "Bolsa de valores oficial do Brasil, onde são negociadas ações, FIIs, ETFs e outros ativos." }
  ]
} 